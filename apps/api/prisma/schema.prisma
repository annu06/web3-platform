generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum NFTStatus {
  UNMINTED
  MINTED
  LISTED
  IN_AUCTION
  SOLD
  BURNED
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
  DROPPED
}

enum ProposalStatus {
  DRAFT
  PENDING
  ACTIVE
  CANCELED
  DEFEATED
  SUCCEEDED
  QUEUED
  EXPIRED
  EXECUTED
}

enum VoteType {
  FOR
  AGAINST
  ABSTAIN
}

enum NotificationType {
  TXN_CONFIRMED
  TXN_FAILED
  NFT_SOLD
  NFT_BOUGHT
  NFT_BID
  PROPOSAL_CREATED
  PROPOSAL_EXECUTED
  REWARD_EARNED
  VOTE_CAST
  SYSTEM
}

// ─────────────────────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  username         String?   @unique
  avatar           String?
  bio              String?
  role             UserRole  @default(USER)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  wallets          Wallet[]
  sessions         Session[]
  proposals        Proposal[]
  votes            Vote[]
  activities       ActivityFeed[]
  notifications    Notification[]
  stakingPositions StakingPosition[]
  transactions     Transaction[]
  auditLogs        AuditLog[]
  settings         UserSettings?

  @@index([email])
  @@map("users")
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  chainId   Int      @default(1)
  isPrimary Boolean  @default(false)
  ens       String?
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([address])
  @@index([userId])
  @@map("wallets")
}

model Session {
  id            String   @id @default(cuid())
  token         String   @unique
  refreshToken  String   @unique
  walletAddress String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  userId        String

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────
// NFTs
// ─────────────────────────────────────────────────────────────

model NFT {
  id           String      @id @default(cuid())
  tokenId      String
  contractAddr String
  chainId      Int         @default(1)
  ownerAddr    String
  tokenUri     String
  txHash       String?
  collectionId String?
  mintedAt     DateTime    @default(now())

  collection   Collection?   @relation(fields: [collectionId], references: [id])
  listings     NFTListing[]
  bids         NFTBid[]
  transfers    NFTTransfer[]

  @@unique([tokenId, contractAddr, chainId])
  @@index([ownerAddr])
  @@index([collectionId])
  @@map("nfts")
}

model Collection {
  id              String   @id @default(cuid())
  name            String
  symbol          String
  description     String?
  imageUri        String?
  contractAddress String?  @unique
  chainId         Int      @default(1)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())

  nfts            NFT[]

  @@map("collections")
}

model NFTListing {
  id        String        @id @default(cuid())
  price     Decimal       @db.Decimal(36, 18)
  currency  String        @default("ETH")
  status    ListingStatus @default(ACTIVE)
  isActive  Boolean       @default(true)
  txHash    String?
  listedAt  DateTime      @default(now())
  expiresAt DateTime?
  soldAt    DateTime?
  nftId     String

  nft       NFT           @relation(fields: [nftId], references: [id])

  @@index([nftId])
  @@index([status])
  @@index([isActive])
  @@map("nft_listings")
}

model NFTBid {
  id       String   @id @default(cuid())
  amount   Decimal  @db.Decimal(36, 18)
  currency String   @default("ETH")
  bidder   String
  txHash   String?
  status   String   @default("ACTIVE")
  placedAt DateTime @default(now())
  nftId    String

  nft      NFT      @relation(fields: [nftId], references: [id])

  @@index([nftId])
  @@map("nft_bids")
}

model NFTTransfer {
  id        String   @id @default(cuid())
  from      String
  to        String
  txHash    String
  blockNum  BigInt
  timestamp DateTime
  nftId     String

  nft       NFT      @relation(fields: [nftId], references: [id])

  @@index([nftId])
  @@map("nft_transfers")
}

// ─────────────────────────────────────────────────────────────
// Transactions
// ─────────────────────────────────────────────────────────────

model Transaction {
  id          String    @id @default(cuid())
  hash        String    @unique
  chainId     Int       @default(1)
  blockNumber BigInt?
  type        String
  status      TxStatus  @default(PENDING)
  from        String
  to          String?
  amount      Decimal?  @db.Decimal(36, 18)
  gasUsed     BigInt?
  gasPrice    BigInt?
  errorMsg    String?
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  userId      String?

  user        User?     @relation(fields: [userId], references: [id])

  @@index([hash])
  @@index([from])
  @@index([userId])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────
// DAO Governance
// ─────────────────────────────────────────────────────────────

model Proposal {
  id             String         @id @default(cuid())
  onChainId      String?        @unique
  title          String
  description    String         @db.Text
  status         ProposalStatus @default(DRAFT)
  calldata       String?
  targetAddr     String?
  forVotes       Decimal        @default(0) @db.Decimal(36, 18)
  againstVotes   Decimal        @default(0) @db.Decimal(36, 18)
  abstainVotes   Decimal        @default(0) @db.Decimal(36, 18)
  startBlock     BigInt?
  endBlock       BigInt?
  executedAt     DateTime?
  cancelledAt    DateTime?
  txHash         String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  proposerId     String

  proposer       User           @relation(fields: [proposerId], references: [id])
  votes          Vote[]

  @@index([status])
  @@index([proposerId])
  @@map("proposals")
}

model Vote {
  id         String    @id @default(cuid())
  support    VoteType
  weight     Decimal   @default(1) @db.Decimal(36, 18)
  reason     String?
  txHash     String?
  castAt     DateTime  @default(now())
  proposalId String
  userId     String

  proposal   Proposal  @relation(fields: [proposalId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([proposalId, userId])
  @@index([proposalId])
  @@index([userId])
  @@map("votes")
}

// ─────────────────────────────────────────────────────────────
// DeFi Staking
// ─────────────────────────────────────────────────────────────

model StakingPosition {
  id           String    @id @default(cuid())
  poolId       Int
  amount       Decimal   @db.Decimal(36, 18)
  rewardDebt   Decimal   @default(0) @db.Decimal(36, 18)
  totalClaimed Decimal   @default(0) @db.Decimal(36, 18)
  txHash       String?
  chainId      Int       @default(1)
  stakedAt     DateTime  @default(now())
  userId       String

  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([poolId])
  @@map("staking_positions")
}

// ─────────────────────────────────────────────────────────────
// Treasury
// ─────────────────────────────────────────────────────────────

model TreasuryTransaction {
  id         String   @id @default(cuid())
  txHash     String   @unique
  type       String
  token      String   @default("ETH")
  amount     Decimal  @db.Decimal(36, 18)
  from       String?
  to         String?
  note       String?
  executedAt DateTime @default(now())

  @@index([type])
  @@map("treasury_transactions")
}

// ─────────────────────────────────────────────────────────────
// Notifications & Activity
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  link      String?
  txHash    String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  userId    String

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model ActivityFeed {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  txHash    String?
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activity_feed")
}

// ─────────────────────────────────────────────────────────────
// Analytics
// ─────────────────────────────────────────────────────────────

model DailySnapshot {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  tvl               Decimal  @default(0) @db.Decimal(36, 18)
  totalUsers        Int      @default(0)
  totalNfts         Int      @default(0)
  totalTransactions Int      @default(0)
  stakingApr        Decimal? @db.Decimal(8, 4)

  @@map("daily_snapshots")
}

// ─────────────────────────────────────────────────────────────
// Audit & Settings
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model UserSettings {
  id                 String  @id @default(cuid())
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(false)
  darkMode           Boolean @default(true)
  language           String  @default("en")
  expertMode         Boolean @default(false)
  gasPreference      String  @default("standard")
  userId             String  @unique

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}
